 FrameWidgetClass rootFrame {
 size 1 1
 hexactpos 0
 vexactpos 0
 hexactsize 0
 vexactsize 0
 {
  PanelWidgetClass background {
   ignorepointer 1
   color 0 0 0 0.1961
   size 1 1
   hexactpos 0
   vexactpos 0
   hexactsize 0
   vexactsize 0
   style rover_sim_colorable
   {
    ImageWidgetClass menuBar {
     ignorepointer 1
     color 0.1137 0.1137 0.1137 0.95
     position 0 0
     size 1 0.055
     halign center_ref
     valign bottom_ref
     hexactpos 0
     vexactpos 0
     hexactsize 0
     vexactsize 0
     mode blend
     {
      TextWidgetClass textMiningStatus {
       ignorepointer 1
       position 0.01 0
       size 0.28 1
       halign left_ref
       hexactpos 0
       vexactpos 0
       hexactsize 0
       vexactsize 0
       text "IDLE"
       color 0.5 0.5 0.5 1
       font "gui/fonts/etelkatextpro18"
       "exact text" 1
       "text halign" left
       "text valign" center
      }
      GridSpacerWidgetClass gridEnergyBattery {
       ignorepointer 1
       position 0 0
       size 0.1 1
       halign right_ref
       valign bottom_ref
       hexactpos 0
       vexactpos 0
       hexactsize 0
       vexactsize 0
       "Size To Content H" 1
       Columns 2
       Rows 1
       {
        ImageWidgetClass imgBattery {
         ignorepointer 1
         size 0.379 1.414
         halign center_ref
         valign center_ref
         hexactpos 0
         vexactpos 0
         hexactsize 0
         vexactsize 0
         imageTexture "{39E8734AE8730203}Basecameras/datasets/images/battery-status.edds"
         mode blend
         "src alpha" 1
         "no wrap" 0
         stretch 1
        }
        TextWidgetClass textBatteryPerCent {
         ignorepointer 1
         position 0 0
         size 0.453 1
         halign center_ref
         valign center_ref
         hexactpos 0
         vexactpos 0
         hexactsize 0
         vexactsize 0
         text "---"
         font "gui/fonts/etelkatextpro28"
         "exact text" 1
         "text halign" center
         "text valign" center
        }
       }
      }
      XComboBoxWidgetClass comboSwitchCamera {
       position 0 0
       size 0.303 1
       halign center_ref
       valign center_ref
       hexactpos 0
       vexactpos 0
       hexactsize 0
       vexactsize 0
       items "No Camera"
      }
     }
    }
